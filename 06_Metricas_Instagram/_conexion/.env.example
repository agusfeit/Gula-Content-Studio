# Copiá este archivo a `.env` y completá los valores.
# El `.env` está en .gitignore: NUNCA se commitea (contiene el token).

# Id de la cuenta de Instagram Business/Creator de Gula.
# Si no lo sabés, corré:  node fetch-metricas.mjs --discover
IG_USER_ID=

# Token de acceso de la Graph API (long-lived recomendado, dura ~60 días).
# Permisos necesarios: instagram_basic, instagram_manage_insights,
# pages_read_engagement, pages_show_list.
IG_ACCESS_TOKEN=

# Versión de la Graph API (opcional, default v22.0).
# GRAPH_VERSION=v22.0
